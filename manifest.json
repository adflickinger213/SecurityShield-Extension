{
    "manifest_version": 3,
    "name": "Security Shield",
    "version": "1.0.0",
    "description": "Enhanced security with phishing detection, HTTPS enforcement, and threat warnings",
    "permissions": ["activeTab", "storage"],
    "host_permissions": ["https://*/*", "http://*/*"],
    "background": {
          "service_worker": "background.js"
    },
    "content_scripts": [
          {
                  "matches": ["https://*/*", "http://*/*"],
                  "js": ["content.js"],
                  "run_at": "document_start"
          }
    ],
    "action": {
          "default_popup": "popup.html"
    }
}
